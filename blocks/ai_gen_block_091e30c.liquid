{% doc %}
  @prompt
    Create a minimal, premium custom landing page section for a smart lock brand called Sentrya. Inspired by level.co/level-lock-pro. Include: an animated hero section with a bold headline and subtle fade-in text, an animated product showcase with scroll-triggered reveal effects, a parallax or smooth scroll experience, a clean dark/light minimal color palette with premium feel, feature highlights section with icons that animate in on scroll, and a strong call-to-action button. All animations should feel smooth and high-end, not flashy. The design should convey trust, security, and modern technology.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .sentrya-landing-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    overflow: hidden;
  }

  .sentrya-hero-{{ ai_gen_id }} {
    min-height: {{ block.settings.hero_height }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 80px 20px;
    background: {{ block.settings.hero_background }};
  }

  .sentrya-hero-content-{{ ai_gen_id }} {
    max-width: 900px;
    text-align: center;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1.2s ease-out, transform 1.2s ease-out;
  }

  .sentrya-hero-content-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sentrya-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 24px;
    letter-spacing: -0.02em;
  }

  .sentrya-hero-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    line-height: 1.6;
    margin: 0 0 40px;
    opacity: 0.9;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .sentrya-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: 18px 48px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .sentrya-cta-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.25);
  }

  .sentrya-product-showcase-{{ ai_gen_id }} {
    padding: 120px 20px;
    position: relative;
  }

  .sentrya-showcase-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .sentrya-product-image-wrapper-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateX(-50px);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }

  .sentrya-product-image-wrapper-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .sentrya-product-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .sentrya-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: {{ block.settings.product_image_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sentrya-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .sentrya-product-details-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateX(50px);
    transition: opacity 1s ease-out 0.2s, transform 1s ease-out 0.2s;
  }

  .sentrya-product-details-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .sentrya-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 700;
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .sentrya-product-description-{{ ai_gen_id }} {
    font-size: 18px;
    line-height: 1.7;
    opacity: 0.85;
  }

  .sentrya-features-{{ ai_gen_id }} {
    padding: 120px 20px;
    background-color: {{ block.settings.features_bg_color }};
  }

  .sentrya-features-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sentrya-features-heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.features_heading_size }}px;
    font-weight: 700;
    margin: 0 0 80px;
    color: {{ block.settings.features_text_color }};
  }

  .sentrya-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 60px;
  }

  .sentrya-feature-item-{{ ai_gen_id }} {
    text-align: center;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .sentrya-feature-item-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sentrya-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_bg_color }};
    border-radius: 50%;
    color: {{ block.settings.icon_color }};
  }

  .sentrya-feature-icon-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .sentrya-feature-title-{{ ai_gen_id }} {
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 12px;
    color: {{ block.settings.features_text_color }};
  }

  .sentrya-feature-description-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.6;
    opacity: 0.8;
    color: {{ block.settings.features_text_color }};
  }

  .sentrya-cta-section-{{ ai_gen_id }} {
    padding: 120px 20px;
    text-align: center;
    background: {{ block.settings.cta_section_bg }};
  }

  .sentrya-cta-section-content-{{ ai_gen_id }} {
    max-width: 700px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s ease-out, transform 1s ease-out;
  }

  .sentrya-cta-section-content-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .sentrya-cta-section-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_section_heading_size }}px;
    font-weight: 700;
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .sentrya-cta-section-text-{{ ai_gen_id }} {
    font-size: 18px;
    line-height: 1.6;
    margin: 0 0 40px;
    opacity: 0.85;
  }

  @media screen and (max-width: 768px) {
    .sentrya-hero-{{ ai_gen_id }} {
      min-height: 70vh;
      padding: 60px 20px;
    }

    .sentrya-hero-headline-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.headline_size }}px * 0.6);
    }

    .sentrya-hero-subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtext_size }}px * 0.9);
    }

    .sentrya-showcase-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .sentrya-product-image-wrapper-{{ ai_gen_id }},
    .sentrya-product-details-{{ ai_gen_id }} {
      transform: translateY(30px);
    }

    .sentrya-product-image-wrapper-{{ ai_gen_id }}.visible,
    .sentrya-product-details-{{ ai_gen_id }}.visible {
      transform: translateY(0);
    }

    .sentrya-product-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.product_title_size }}px * 0.7);
    }

    .sentrya-features-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.features_heading_size }}px * 0.7);
    }

    .sentrya-cta-section-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.cta_section_heading_size }}px * 0.7);
    }

    .sentrya-features-grid-{{ ai_gen_id }} {
      gap: 40px;
    }
  }
{% endstyle %}

<sentrya-landing-{{ ai_gen_id }} class="sentrya-landing-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <section class="sentrya-hero-{{ ai_gen_id }}">
    <div class="sentrya-hero-content-{{ ai_gen_id }}" data-animate="hero">
      {% if block.settings.hero_headline != blank %}
        <h1 class="sentrya-hero-headline-{{ ai_gen_id }}">{{ block.settings.hero_headline }}</h1>
      {% endif %}
      {% if block.settings.hero_subtext != blank %}
        <div class="sentrya-hero-subtext-{{ ai_gen_id }}">{{ block.settings.hero_subtext }}</div>
      {% endif %}
      {% if block.settings.hero_cta_text != blank %}
        <a href="{{ block.settings.hero_cta_link }}" class="sentrya-cta-{{ ai_gen_id }}">
          {{ block.settings.hero_cta_text }}
        </a>
      {% endif %}
    </div>
  </section>

  <section class="sentrya-product-showcase-{{ ai_gen_id }}">
    <div class="sentrya-showcase-container-{{ ai_gen_id }}">
      <div class="sentrya-product-image-wrapper-{{ ai_gen_id }}" data-animate="product-image">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1200 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            class="sentrya-product-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
          >
        {% else %}
          <div class="sentrya-product-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="sentrya-product-details-{{ ai_gen_id }}" data-animate="product-details">
        {% if block.settings.product_title != blank %}
          <h2 class="sentrya-product-title-{{ ai_gen_id }}">{{ block.settings.product_title }}</h2>
        {% endif %}
        {% if block.settings.product_description != blank %}
          <div class="sentrya-product-description-{{ ai_gen_id }}">{{ block.settings.product_description }}</div>
        {% endif %}
      </div>
    </div>
  </section>

  <section class="sentrya-features-{{ ai_gen_id }}">
    <div class="sentrya-features-container-{{ ai_gen_id }}">
      {% if block.settings.features_heading != blank %}
        <h2 class="sentrya-features-heading-{{ ai_gen_id }}">{{ block.settings.features_heading }}</h2>
      {% endif %}
      <div class="sentrya-features-grid-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% liquid
            assign feature_title_key = 'feature_' | append: i | append: '_title'
            assign feature_desc_key = 'feature_' | append: i | append: '_description'
            assign feature_title = block.settings[feature_title_key]
            assign feature_desc = block.settings[feature_desc_key]
          %}
          {% if feature_title != blank %}
            <div class="sentrya-feature-item-{{ ai_gen_id }}" data-animate="feature" style="transition-delay: {{ i | times: 0.15 }}s;">
              <div class="sentrya-feature-icon-{{ ai_gen_id }}">
                {% case i %}
                  {% when 1 %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                  {% when 2 %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                  {% when 3 %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                {% endcase %}
              </div>
              <h3 class="sentrya-feature-title-{{ ai_gen_id }}">{{ feature_title }}</h3>
              {% if feature_desc != blank %}
                <div class="sentrya-feature-description-{{ ai_gen_id }}">{{ feature_desc }}</div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="sentrya-cta-section-{{ ai_gen_id }}">
    <div class="sentrya-cta-section-content-{{ ai_gen_id }}" data-animate="cta-section">
      {% if block.settings.cta_section_heading != blank %}
        <h2 class="sentrya-cta-section-heading-{{ ai_gen_id }}">{{ block.settings.cta_section_heading }}</h2>
      {% endif %}
      {% if block.settings.cta_section_text != blank %}
        <div class="sentrya-cta-section-text-{{ ai_gen_id }}">{{ block.settings.cta_section_text }}</div>
      {% endif %}
      {% if block.settings.cta_section_button_text != blank %}
        <a href="{{ block.settings.cta_section_button_link }}" class="sentrya-cta-{{ ai_gen_id }}">
          {{ block.settings.cta_section_button_text }}
        </a>
      {% endif %}
    </div>
  </section>
</sentrya-landing-{{ ai_gen_id }}>

<script>
  (function() {
    class SentryaLanding{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.animatedElements = [];
      }

      connectedCallback() {
        this.setupIntersectionObserver();
        this.animateHeroOnLoad();
      }

      animateHeroOnLoad() {
        const heroContent = this.querySelector('[data-animate="hero"]');
        if (heroContent) {
          setTimeout(() => {
            heroContent.classList.add('visible');
          }, 100);
        }
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.15
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !entry.target.classList.contains('visible')) {
              entry.target.classList.add('visible');
            }
          });
        }, options);

        const animatableElements = this.querySelectorAll('[data-animate]');
        animatableElements.forEach((element) => {
          if (element.dataset.animate !== 'hero') {
            observer.observe(element);
          }
        });
      }
    }

    customElements.define('sentrya-landing-{{ ai_gen_id }}', SentryaLanding{{ ai_gen_id }});
  })();
</script>

